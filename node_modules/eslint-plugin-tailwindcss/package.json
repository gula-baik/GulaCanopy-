{
  "name": "eslint-plugin-tailwindcss",
  "version": "4.0.4",
  "publishConfig": {
    "publish-branch": "v4"
  },
  "license": "MIT",
  "description": "Rules enforcing best practices while using Tailwind CSS",
  "repository": {
    "type": "git",
    "url": "https://github.com/francoismassart/eslint-plugin-tailwindcss"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "tailwind",
    "tailwindcss",
    "typescript"
  ],
  "author": "François Massart",
  "homepage": "https://github.com/francoismassart/eslint-plugin-tailwindcss",
  "bugs": "https://github.com/francoismassart/eslint-plugin-tailwindcss/issues",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.cts",
  "exports": {
    ".": {
      "module": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "docs/",
    "lib/"
  ],
  "dependencies": {
    "@typescript-eslint/utils": "^8.37.0",
    "postcss": "^8.4.4",
    "postcss-nested": "^7.0.2",
    "synckit": "^0.11.11",
    "tailwind-api-utils": "^1.0.3"
  },
  "devDependencies": {
    "@angular-eslint/template-parser": "^20.1.1",
    "@eslint/js": "^9.16.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/eslint": "^8.56.10",
    "@typescript-eslint/parser": "^8.37.0",
    "@typescript-eslint/rule-tester": "^8.37.0",
    "daisyui": "^5.5.23",
    "eslint": "^9.31.0",
    "eslint-doc-generator": "^2.2.2",
    "eslint-plugin-eslint-plugin": "^7.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "globals": "^15.13.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "unbuild": "^3.3.1",
    "vitest": "^1.6.0",
    "vue-eslint-parser": "^10.2.0"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "bench": "vitest bench",
    "build": "unbuild --config unbuild.config.ts  && rsync src/utils/tailwindcss-api/worker/*.mjs lib/worker",
    "docs:init": "eslint-doc-generator --init-rule-docs",
    "docs:update": "eslint-doc-generator",
    "test": "vitest",
    "tsc": "tsc --noEmit"
  }
}